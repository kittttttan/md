---
import { getCollection } from 'astro:content';

export async function getStaticPaths() {
	const posts = await getCollection('posts');
	const tags = [...new Set(posts.flatMap(post => post.data.tags))];
	
	return tags.map(tag => ({
		params: { tag },
	}));
}

const { tag } = Astro.params;
---

<!DOCTYPE html>
<html lang="ja">
<head>
	<meta charset="UTF-8">
	<meta http-equiv="refresh" content={`0;url=/tags/${tag}/1`}>
	<link rel="canonical" href={`/tags/${tag}/1`}>
	<title>Redirecting...</title>
</head>
<body>
	<p>Redirecting to <a href={`/tags/${tag}/1`}>/tags/{tag}/1</a>...</p>
</body>
</html>
