---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import TagBadge from '../../components/TagBadge.astro';

const posts = await getCollection('posts');
const tags = [...new Set(posts.flatMap(post => post.data.tags))].sort();
---

<BaseLayout title="Tags - MD Manager">
	<Header />
	<main>
		<h1 class="text-3xl font-bold mb-8 tracking-tight">All Tags</h1>
		<div class="flex flex-wrap gap-4">
			{tags.map(tag => (
				<div class="flex items-center gap-2 p-4 rounded-2xl border border-slate-200 dark:border-slate-800">
					<TagBadge tag={tag} />
					<span class="text-sm text-slate-400">
						({posts.filter(p => p.data.tags.includes(tag)).length})
					</span>
				</div>
			))}
			{tags.length === 0 && <p class="text-slate-400">タグが見つかりません。</p>}
		</div>
	</main>
</BaseLayout>
